{
  "expo": {
    "name": "MeetPerto",
    "slug": "meetperto",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "meetperto",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF4B8B"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/ec7aa273-0367-4788-bb19-56054fc14529"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meetperto.app",
      "buildNumber": "2.0.0",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "O MeetPerto usa sua localização para mostrar pessoas próximas a você.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "O MeetPerto usa sua localização em segundo plano para te avisar sobre matches próximos.",
        "NSCameraUsageDescription": "Precisamos da câmera para você adicionar fotos ao seu perfil.",
        "NSPhotoLibraryUsageDescription": "Precisamos da galeria para você escolher fotos de perfil.",
        "NSUserTrackingUsageDescription": "Este identificador será usado para entregar anúncios personalizados e métricas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF4B8B"
      },
      "package": "com.meetperto.app",
      "versionCode": 2,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF4B8B"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O MeetPerto usa sua localização para mostrar pessoas próximas a você."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "ec7aa273-0367-4788-bb19-56054fc14529"
      }
    },
    "sdkVersion": "54.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "androidStatusBar": {
      "backgroundColor": "#FF4B8B",
      "barStyle": "light-content"
    }
  }
}
