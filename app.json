{
  "expo": {
    "name": "Meet Perto",
    "slug": "encontro-app",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meetperto.encontroapp",
      "buildNumber": "2",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "O Meet Perto usa sua galeria para você escolher uma foto de perfil.",
        "NSCameraUsageDescription": "O Meet Perto usa a câmera para você tirar uma foto de perfil.",
        "NSMicrophoneUsageDescription": "Permissão de microfone para vídeos no perfil.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.meetperto.encontroapp",
      "versionCode": 2,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "O Meet Perto acessa suas fotos para você escolher uma imagem de perfil.",
          "cameraPermission": "O Meet Perto acessa sua câmera para você tirar uma foto de perfil."
        }
      ],
      "expo-build-properties"
    ],
    "extra": {
      "eas": {
        "projectId": "0bd9f3bd-8ed4-4db8-b6db-441e9c2be1cd"
      }
    },
    "owner": "meetperto-oficial"
  }
}
