rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Função pra validar se é o dono do documento
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Função pra validar se os dois usuários deram match
    function hasMatch(matchId) {
      return request.auth != null && 
             exists(/databases/$(database)/documents/matches/$(matchId)) &&
             request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
    }

    // USERS: Só o próprio usuário escreve. Qualquer logado lê pra ver perfis.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }
    
    // CHATS: Só quem tá no match acessa
    match /chats/{matchId}/messages/{messageId} {
      allow read, create: if hasMatch(matchId);
      allow update, delete: if request.auth.uid == resource.data.senderId;
    }
    
    // MATCHES: Só os 2 usuários do match podem ver
    match /matches/{matchId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.users;
    }
    
    // LIKES: Só o usuário pode criar seu like. Ninguém lê like de outros.
    match /likes/{likeId} {
      allow read: if request.auth.uid == resource.data.toUserId;
      allow create: if request.auth.uid == request.resource.data.fromUserId;
      allow delete: if false; // Cloud Function cuida disso
    }
    
    // REPORTS: Só cria, não lê nem edita
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
    
    // Bloqueia todo o resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
